/* 推荐页 —— 清爽浅色渐变 · 干净白卡 */
page {
  background: linear-gradient(180deg, #fdf2ec 0%, #f5eef0 42%, #f1eef2 100%);
  background-attachment: fixed;
}
.page {
  min-height: 100vh;
}

/* ---------- 顶部 Hero：图片背景卡片 ---------- */
.hero-card {
  position: relative;
  height: 430rpx;
  margin: 24rpx 28rpx 28rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(120, 110, 120, 0.2);
}
.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: #eee;
}
.hero-scrim {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.5) 0%, rgba(0, 0, 0, 0.12) 42%, rgba(0, 0, 0, 0) 70%);
}
.hero-content {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  padding: 36rpx;
}
.greeting {
  font-size: 54rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.4);
}
.subtitle {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.95);
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.4);
}
.hero-weather {
  align-self: flex-start;
  margin-top: auto;
  font-size: 22rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
}

.body {
  padding: 0 28rpx 60rpx;
}

/* ---------- 干净白卡通用观感 ---------- */
.summary-bar,
.panel,
.card {
  background: #ffffff;
  box-shadow: 0 8rpx 26rpx rgba(120, 110, 120, 0.14);
}

/* 折叠摘要条 */
.summary-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-radius: 28rpx;
  padding: 26rpx 30rpx;
  margin-bottom: 26rpx;
}
.summary-left {
  display: flex;
  flex-direction: column;
  min-width: 0;
}
.summary-label {
  font-size: 21rpx;
  color: #9a9095;
  letter-spacing: 2rpx;
  margin-bottom: 6rpx;
}
.summary-text {
  font-size: 28rpx;
  color: #2f2a26;
  font-weight: 600;
}
.summary-edit {
  font-size: 25rpx;
  color: #ff6b3d;
  flex-shrink: 0;
  margin-left: 16rpx;
  font-weight: 500;
}

/* ---------- 面板 ---------- */
.panel {
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
}
.field-label {
  font-size: 25rpx;
  color: #2f2a26;
  font-weight: 600;
  letter-spacing: 1rpx;
  margin: 36rpx 0 20rpx;
}
.field-label:first-child {
  margin-top: 0;
}
.field-tip {
  font-size: 21rpx;
  color: #a89ea2;
  font-weight: 400;
  margin-left: 12rpx;
}

/* 标签 */
.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}
.chip {
  font-size: 26rpx;
  color: #6b625e;
  background: #f4f5f7;
  border: 1rpx solid transparent;
  border-radius: 999rpx;
  padding: 15rpx 30rpx;
  transition: all 0.18s;
}
.chip-crave--active {
  color: #ff6b3d;
  background: rgba(255, 122, 69, 0.12);
  border-color: rgba(255, 122, 69, 0.55);
  font-weight: 600;
}

/* 二级选择 */
.chips-variant {
  margin-top: 18rpx;
  padding: 20rpx;
  background: #f7f8fa;
  border-radius: 20rpx;
}
.chip-variant {
  background: #fff;
  color: #6b625e;
  border: 1rpx solid #e8e6ea;
}
.chip-variant--active {
  color: #ff6b3d;
  background: #fff;
  border-color: #ff6b3d;
  font-weight: 600;
}
.vd {
  font-size: 20rpx;
  color: #b0a6aa;
  font-weight: 400;
}
.chip-variant--active .vd {
  color: #ff9a72;
}
.hint-inline {
  margin-top: 16rpx;
  font-size: 21rpx;
  color: #a89ea2;
}

/* 时间松紧 */
.urgency {
  display: flex;
  gap: 18rpx;
}
.urg-item {
  flex: 1;
  text-align: center;
  background: #f4f5f7;
  border: 1rpx solid transparent;
  border-radius: 22rpx;
  padding: 24rpx 0;
  transition: all 0.18s;
}
.urg-item--active {
  background: rgba(255, 122, 69, 0.1);
  border-color: rgba(255, 122, 69, 0.5);
}
.urg-label {
  font-size: 28rpx;
  color: #3a342f;
}
.urg-item--active .urg-label {
  color: #ff6b3d;
  font-weight: 600;
}
.urg-desc {
  font-size: 21rpx;
  color: #a89ea2;
  margin-top: 8rpx;
}
.urg-item--active .urg-desc {
  color: #e08a5f;
}

/* 提交按钮 */
.btn-submit {
  width: 100%;
  box-sizing: border-box;
  margin-top: 48rpx;
  padding: 24rpx 20rpx;
  background: #ffffff;
  color: #1f1f1f;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  white-space: nowrap;
  font-family: "SF Pro Rounded", ui-rounded, -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.12);
}
.btn-submit::after {
  border: none;
}

/* ---------- 提示 / 加载 ---------- */
.hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 90rpx 0;
  color: #8a807c;
  font-size: 28rpx;
}
.hint-err {
  color: #c0506a;
  margin-bottom: 24rpx;
}
.spinner {
  width: 56rpx;
  height: 56rpx;
  border: 5rpx solid #f0ecec;
  border-top-color: #ff6b3d;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}
@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* ---------- 列表 ---------- */
.list {
  margin-top: 6rpx;
}
.meta-debug {
  font-size: 21rpx;
  color: #8a7c77;
  background: #f5ece7;
  border-radius: 10rpx;
  padding: 10rpx 16rpx;
  margin-bottom: 18rpx;
}
.meta-err {
  font-size: 21rpx;
  color: #c0506a;
  word-break: break-all;
  margin-bottom: 18rpx;
}

.card {
  display: flex;
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 22rpx;
}
.card--first {
  background: linear-gradient(180deg, #fff8f4 0%, #ffffff 55%);
}
.card-thumb-wrap {
  position: relative;
  width: 160rpx;
  flex-shrink: 0;
  margin-right: 22rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.card-thumb {
  width: 160rpx;
  height: 100%;
  min-height: 160rpx;
  display: block;
  background: #f0eef0;
}
.card-thumb--ph {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  background: #f6f1ee;
}
.rank-badge {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  line-height: 32rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 10rpx;
}
.rank-badge--top {
  background: #ff6b3d;
}
.card-body {
  flex: 1;
  min-width: 0;
}
.card-top {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.name {
  font-size: 32rpx;
  font-weight: 700;
  color: #222222;
}
.score {
  font-size: 24rpx;
  color: #ff6b3d;
  font-weight: 700;
  flex-shrink: 0;
  margin-left: 12rpx;
}
.score::after {
  content: "分";
  font-size: 18rpx;
  font-weight: 400;
}
.tags {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.tag {
  font-size: 22rpx;
  color: #8c8c8c;
  background: rgba(0, 0, 0, 0.04);
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
}
.tag-dist {
  color: #ff6b3d;
  background: rgba(255, 122, 69, 0.1);
}
.reason {
  margin-top: 18rpx;
  font-size: 25rpx;
  color: #555555;
  line-height: 1.6;
  background: #f7f7f8;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
}
.actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
}
.fb-group {
  display: flex;
  gap: 16rpx;
}
.fb {
  font-size: 30rpx;
  width: 64rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border: 1rpx solid #ececef;
  border-radius: 16rpx;
  background: #f7f8fa;
  filter: grayscale(0.4);
}
.fb--like,
.fb--ok,
.fb--no {
  filter: none;
  border-color: #ff6b3d;
  background: rgba(255, 122, 69, 0.08);
}
.nav {
  font-size: 25rpx;
  color: #ff6b3d;
  font-weight: 500;
  flex-shrink: 0;
}

/* 换一批 */
.btn-refresh {
  margin-top: 10rpx;
  background: #fff;
  color: #ff6b3d;
  border: 1rpx solid rgba(255, 122, 69, 0.35);
  border-radius: 999rpx;
  font-size: 29rpx;
  font-weight: 500;
}
.btn-refresh::after {
  border: none;
}
.btn-line {
  margin-top: 10rpx;
  background: #ff6b3d;
  color: #fff;
  font-size: 28rpx;
  border-radius: 999rpx;
  padding: 0 48rpx;
}
.btn-line::after {
  border: none;
}
